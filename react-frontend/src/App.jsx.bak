          <p className="text-lg text-slate-500 font-mono tracking-[0.2em] mt-6 ml-2">Available Lattice Structures: {COMMUNITY_TRACKS.length.toString().padStart(2, '0')}</p>
        </motion.div>
      </header>

      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 px-4">
        {COMMUNITY_TRACKS.map((c, i) => (
          <motion.div
            key={c.id}
            {...BENTO_ITEM}
            transition={{ delay: i * 0.05 }}
            className="glass-card p-10 flex flex-col justify-between h-[340px] glass-card-hover group border-white/5 bg-charcoal-900/40"
          >
            <div>
              <div className="flex justify-between items-start mb-8 font-mono text-[10px] tracking-[0.3em] uppercase">
                <span className="text-slate-600">{c.modules} Units</span>
                <span className={c.level === 'Extreme' ? 'text-rose-500' : 'text-cyan/80'}>{c.level}</span>
              </div>
              <h3 className="text-4xl font-black font-display leading-[0.95] uppercase tracking-tighter group-hover:text-cyan group-hover:scale-[1.02] origin-left transition-all duration-500">{c.skill_name}</h3>
              <p className="text-[10px] font-mono text-slate-600 mt-6 uppercase tracking-[0.4em]">Node_{c.owner}</p>
            </div>
            <div className="flex justify-between items-center">
               <div className="flex gap-1">
                 {[1,2,3].map(j => <div key={j} className="w-1 h-3 bg-white/10 rounded-full" />)}
               </div>
              <Button variant="outline" className="text-[10px] uppercase tracking-[0.3em] px-8 py-3 border-white/10 group-hover:border-cyan/50 transition-colors">Clone_Path</Button>
            </div>
          </motion.div>
        ))}
      </div>
    </div>
  )
}

function GeneratePage({ token, onGenerate }) {
  const [skill, setSkill] = useState('')
  const [level, setLevel] = useState(1)
  const [loading, setLoading] = useState(false)

  const handleGenerate = () => {
    if (!skill) return
    setLoading(true)
    setTimeout(() => {
      setLoading(false)
      onGenerate()
    }, 3000)
  }

  return (
    <div className="max-w-4xl mx-auto px-8 py-32 w-full text-center flex flex-col items-center justify-center min-h-screen">
      <motion.div {...FADE_UP} className="w-full">
        <div className="inline-flex items-center gap-4 glass px-6 py-2.5 rounded-full border-cyan/20 text-cyan mb-12 shadow-cyan-glow/10">
          <motion.span animate={{ rotate: 360 }} transition={{ duration: 6, repeat: Infinity, ease: 'linear' }}><IcoCompass /></motion.span>
          <span className="text-[11px] font-mono uppercase tracking-[0.4em] font-black">Neural_Architect_v2.5</span>
        </div>
        <h1 className="text-8xl md:text-9xl font-black font-display mb-12 leading-[0.8] tracking-tightest uppercase">Path <br/><span className="text-shimmer">Synthesis</span></h1>
        
        <div className="glass-card p-16 space-y-16 text-left relative overflow-hidden bg-charcoal-900/60 backdrop-blur-2xl border-white/10 shadow-2xl">
          <div className="absolute top-0 right-0 p-8 opacity-5 pointer-events-none scale-[5] translate-x-12 translate-y-[-20%]"><IcoPlus /></div>
          
          <div className="space-y-6">
            <label className="text-[11px] uppercase tracking-[0.5em] font-mono text-slate-600 block px-4">Subject_Objective</label>
            <input 
              placeholder="e.g. SYSTEMS_RUST, QUANTUM_OS, ARCHITECTURAL_PHOTOGRAPHY..."
              className="w-full bg-white/5 border border-white/10 rounded-3xl p-8 text-3xl font-display font-black uppercase tracking-tighter focus:outline-none focus:border-cyan/50 focus:ring-1 focus:ring-cyan/20 transition-all duration-700 shadow-inner"
              value={skill}
              onChange={(e) => setSkill(e.target.value)}
            />
          </div>

          <div className="space-y-10">
             <div className="flex justify-between items-end px-4">
               <label className="text-[11px] uppercase tracking-[0.5em] font-mono text-slate-600 block">Baseline_Competency</label>
               <span className="text-4xl font-display font-black text-cyan leading-none">{level}/10</span>
             </div>
             <input 
               type="range" min="1" max="10" 
               className="w-full h-2 bg-white/5 rounded-full appearance-none cursor-pointer accent-cyan shadow-inner"
               value={level}
               onChange={(e) => setLevel(e.target.value)}
             />
             <div className="flex justify-between text-[10px] font-mono text-slate-700 uppercase tracking-[0.4em] px-4 font-black">
               <span>INITIATE</span>
               <span>EXPERT</span>
             </div>
          </div>

          <Button 
            disabled={!skill || loading} 
            onClick={handleGenerate}
            className="w-full py-8 text-xl font-display font-black tracking-[0.4em] uppercase hover:tracking-[0.6em] transition-all duration-1000 mt-6 shadow-cyan-glow/20"
          >
            {loading ? 'Synthesizing_Lattice...' : 'Initialize_Arch_Cycle'}
          </Button>
        </div>
      </motion.div>
    </div>
  )
}

async function fetchCourses(token) {
  try {
    const res = await fetch(`${API}/courses`, { headers: { Authorization: `Bearer ${token}` } })
    if (!res.ok) return []
    const list = await res.json()
    const detailed = await Promise.all(list.map(async c => {
      try {
        const r = await fetch(`${API}/courses/${c.id}`, { headers: { Authorization: `Bearer ${token}` } })
        if (!r.ok) return { ...c, modules: [] }
        const d = await r.json()
        return { ...d.course, modules: d.modules || [] }
      } catch { return { ...c, modules: [] } }
    }))
    return detailed
  } catch { return [] }
}

export default function App() {
  const [user, setUser] = useState(null)
  const [page, setPage] = useState('dashboard')
  const [courses, setCourses] = useState([])
  const [selected, setSelected] = useState(null)
  const [showLanding, setShowLanding] = useState(true)

  useEffect(() => {
    const token = localStorage.getItem('op_token')
    if (token && !user) {
      // Simple decode or just assuming it's valid for this mock/demo
      // Normally we'd fetch user info here
    }
  }, [])

  const login = async userData => {
    setUser(userData)
    setPage('dashboard')
    const userCourses = await fetchCourses(userData.token)
    setCourses(userCourses)
  }

  const logout = () => {
    setUser(null); setCourses([]); setSelected(null); setPage('dashboard')
    localStorage.removeItem('op_token')
  }

  const refreshCourses = async () => {
    if (!user?.token) return
    const userCourses = await fetchCourses(user.token)
    setCourses(userCourses)
  }

  const completeModule = async (modId, type) => {
    setCourses(prev => prev.map(c => ({
      ...c,
      modules: c.modules.map(m => m.id !== modId ? m : { ...m, is_completed: true, is_skipped: type === 'skipped' })
    })))
    if (selected) {
      setSelected(prev => ({
        ...prev,
        modules: prev.modules.map(m => m.id !== modId ? m : { ...m, is_completed: true, is_skipped: type === 'skipped' })
      }))
    }
    try {
      await fetch(`${API}/${type === 'skipped' ? 'submit-quiz?score=5&' : 'modules/'}module_id=${modId}${type !== 'skipped' ? '/complete' : ''}`, {
        method: 'POST', headers: { Authorization: `Bearer ${user.token}` }
      })
    } catch (e) { console.error(e) }
  }

  const saveNotes = async (modId, text) => {
    try {
      await fetch(`${API}/modules/${modId}/notes`, {
        method: 'PATCH', headers: { Authorization: `Bearer ${user.token}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ notes: text }),
      })
    } catch (e) { console.error(e) }
  }

  if (showLanding) return <LandingPage onGetStarted={() => setShowLanding(false)} />
  if (!user) return <AuthScreen onLogin={login} />

  return (
    <div className="min-h-screen bg-charcoal-950 flex flex-col font-sans text-slate-200">
      <NavPill active={page} setPage={setPage} user={user} onLogout={logout} />
      
      <main className="flex-1 overflow-x-hidden flex flex-col relative">
        <div className="fixed inset-0 bg-charcoal-900 opacity-20 pointer-events-none">
          <div className="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cyan/20 to-transparent" />
          <div className="absolute inset-y-0 left-0 w-px bg-gradient-to-b from-transparent via-cyan/10 to-transparent" />
        </div>
        
        <AnimatePresence mode="wait">
          <motion.div
            key={page}
            initial={{ opacity: 0, y: 15 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -15 }}
            transition={{ duration: 0.6, ease: [0.16, 1, 0.3, 1] }}
            className="flex-1 flex flex-col relative z-10"
          >
            {page === 'dashboard' && <Dashboard courses={courses} onSelectCourse={(c) => { setSelected(c); setPage('course') }} user={user} />}
            {page === 'course' && selected && (
              <CourseView 
                course={selected} 
                onBack={() => setPage('dashboard')} 
                onComplete={completeModule} 
                onSaveNotes={saveNotes}
                token={user.token}
              />
            )}
            {page === 'discover' && <DiscoverPage token={user.token} onEnroll={refreshCourses} />}
            {page === 'generate' && <GeneratePage token={user.token} onGenerate={() => { refreshCourses(); setPage('dashboard') }} />}
          </motion.div>
        </AnimatePresence>
      </main>
    </div>
  )
}
