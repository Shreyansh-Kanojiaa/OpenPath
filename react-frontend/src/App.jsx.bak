    { id:102, skill_name:'Generative AI Design', owner:'neural_flow', modules:8, level:'Complex' },
    { id:103, skill_name:'Orbital Mechanics', owner:'spacewalk', modules:15, level:'Extreme' },
    { id:104, skill_name:'Surgical Compositing', owner:'zero_depth', modules:6, level:'Advanced' },
    { id:105, skill_name:'Protocol Analysis', owner:'shadow_net', modules:10, level:'Complex' },
  ]

  return (
    <div className="max-w-7xl mx-auto px-8 py-32 w-full min-h-screen">
      <header className="mb-24 px-4 overflow-hidden relative">
