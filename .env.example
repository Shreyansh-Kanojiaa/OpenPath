# Copy this file to .env and fill in real values. .env is gitignored and must
# never be committed. On the server, `docker compose` reads .env automatically.

# ─── Gemini API ───────────────────────────────────────────────────────────────
# Your Google AI Studio key. If left blank the app still runs, degrading to
# hardcoded mock responses. Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# ─── Environment ──────────────────────────────────────────────────────────────
# "production" makes JWT_SECRET_KEY mandatory (the app refuses to start without it).
# "development" generates a throwaway key if one is not set. Use production on the server.
ENVIRONMENT="production"

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate a strong random value, do not reuse a guessable one:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=""
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="1440"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed frontend origins. On the server set this to your HTTPS
# domain(s). Because the frontend calls the API through nginx's /api proxy on the
# same origin, this mainly matters for any direct cross-origin calls.
#   Local dev:  http://localhost:5173,http://127.0.0.1:5173,http://localhost
#   Production: https://your-domain.com,https://www.your-domain.com
CORS_ORIGINS="https://your-domain.com,https://www.your-domain.com"

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Used by both the db container and the backend's DATABASE_URL (assembled in compose).
# Avoid special characters like @ in the password: it is interpolated unescaped into
# the connection string and would break it.
POSTGRES_USER="openpath"
POSTGRES_PASSWORD="change_me_to_a_strong_password"
POSTGRES_DB="openpath_db"

# ─── Host port overrides (dev only, optional) ─────────────────────────────────
# The dev compose publishes these on the host. Change if the defaults are taken.
# Production ignores them (only nginx is published, on 80/443).
# BACKEND_PORT=8000
# FRONTEND_PORT=80
